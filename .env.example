# === Backend Environment Variables ===
# Set these on Railway (or locally in .env)

# Groq LLM (required)
GROQ_API_KEY=your_groq_api_key_here

# Frontend URL for CORS (set on Railway after Vercel deploy)
FRONTEND_URL=https://your-app.vercel.app

# Optional: Override LLM settings (defaults from config.yaml)
# LLM_PROVIDER=groq
# LLM_MODEL=llama-3.3-70b-versatile
